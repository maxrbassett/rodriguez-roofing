---
import * as site from '@data/site';

const icons: Record<string, string> = {
  badge: 'M12 3 l2.2 1.3 2.5-.3 1 2.3 2.3 1 -.3 2.5 1.3 2.2 -1.3 2.2 .3 2.5 -2.3 1 -1 2.3 -2.5-.3 -2.2 1.3 -2.2-1.3 -2.5.3 -1-2.3 -2.3-1 .3-2.5 -1.3-2.2 1.3-2.2 -.3-2.5 2.3-1 1-2.3 2.5.3z M9 12 l2 2 4-4',
  star: 'M12 3 l2.7 5.5 6 .9 -4.3 4.2 1 6 -5.4-2.8 -5.4 2.8 1-6 -4.3-4.2 6-.9z',
  language: 'M4 5 h9 M8.5 5 V3 M11 5 c0 4-3.4 7-7 8 M6 8.5 c.6 2.4 2.6 4.4 5 5.4 M13 20 l4-9 4 9 M14.7 17 h4.6',
  search: 'M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14z M20 20 l-3.5-3.5',
};
---

<section id="trust" class="bg-white py-16 sm:py-24" aria-labelledby="trust-title">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p class="mb-2 font-display text-sm font-600 uppercase tracking-[0.22em] text-sky">Why homeowners choose us</p>
    <h2 id="trust-title" class="font-display text-3xl font-800 uppercase text-slate-deep sm:text-4xl">
      A licensed local team you can trust
    </h2>
    <p class="mt-3 max-w-2xl text-lg text-steel">
      {site.trust.baseLine} · {site.trust.highlights.join(' · ')}
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {site.trust.points.map((p) => (
        <div class="rounded-xl border border-steel-300 bg-cloud p-6 text-center">
          <span aria-hidden="true" class="mx-auto mb-4 grid h-14 w-14 place-items-center rounded-full bg-slate-deep/5">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#1c6fb5" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d={icons[p.icon]} />
            </svg>
          </span>
          <h3 class="font-display text-lg font-700 text-slate-deep">{p.title}</h3>
          <p class="mt-2 text-sm text-steel">{p.body}</p>
        </div>
      ))}
    </div>

    {/* New business — no reviews yet. An honest note instead of fabricated testimonials. */}
    <div class="mt-12 rounded-2xl border border-steel-300 bg-cloud p-8 text-center">
      <h3 class="font-display text-2xl font-700 uppercase text-slate-deep">Reviews coming soon</h3>
      <p class="mx-auto mt-3 max-w-2xl text-steel">{site.reviewsNote}</p>
      <a
        href="#quote"
        class="mt-5 inline-flex items-center justify-center rounded-full bg-sky px-6 py-3 font-display text-sm font-600 uppercase tracking-wide text-white no-underline transition-colors hover:bg-sky-deep"
      >
        Ask us for references
      </a>
    </div>
  </div>
</section>
