---
import * as site from '@data/site';

// Inline icon paths keyed by service.icon (24x24 viewBox, stroke-based).
const icons: Record<string, string> = {
  shingle: 'M3 11 L12 4 L21 11 M5 11 V20 H19 V11 M8 14 H16 M8 17 H16',
  wrench: 'M14.5 6.5a3.5 3.5 0 0 1-4.6 4.6L5 16l3 3 4.9-4.9a3.5 3.5 0 0 1 4.6-4.6l-2 2-1.5-1.5 2-2z',
  search: 'M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14z M20 20 l-3.5-3.5',
  storm: 'M7 14a4 4 0 0 1 .5-7.9 5 5 0 0 1 9.6 1.4A3.5 3.5 0 0 1 16.5 14 M13 13 l-3 5 h3 l-1 3',
  gutter: 'M4 8 H20 V12 a3 3 0 0 1-3 3 H7 a3 3 0 0 1-3-3 Z M4 8 V6 M20 8 V6 M9 18 v2 M15 18 v2',
  building: 'M5 21 V5 a1 1 0 0 1 1-1 h7 a1 1 0 0 1 1 1 v16 M14 21 V9 h4 a1 1 0 0 1 1 1 v11 M8 8 h2 M8 12 h2 M8 16 h2',
  hammer: 'M14 6 l4 4 M16 4 l4 4 -2 2 -4-4 z M15 9 L5 19 l0 0 -2-2 10-10',
  drop: 'M12 3 c4 5 6 8 6 11 a6 6 0 0 1-12 0 c0-3 2-6 6-11 z',
  maintenance: 'M11 4a7 7 0 1 0 7 7 M11 4 v7 h7 M14.5 14.5 l3.5 3.5 2-2 -3.5-3.5',
};
---

<section id="services" class="bg-cloud py-16 sm:py-24" aria-labelledby="services-title">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p class="mb-2 font-display text-sm font-600 uppercase tracking-[0.22em] text-sky">What we do</p>
    <h2 id="services-title" class="font-display text-3xl font-800 uppercase text-slate-deep sm:text-4xl">
      Roofing services
    </h2>
    <p class="mt-3 max-w-2xl text-lg text-steel">
      Residential and commercial roofing across the Carolinas — done safely, cleanly, and built to last.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {site.services.map((s) => (
        <article class="rounded-xl border border-steel-300 bg-white p-6 transition-shadow hover:shadow-lg">
          <span aria-hidden="true" class="mb-4 grid h-12 w-12 place-items-center rounded-lg bg-slate-deep/5">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2c557a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={icons[s.icon]} />
            </svg>
          </span>
          <h3 class="font-display text-xl font-700 text-slate-deep">{s.title}</h3>
          <p class="mt-2 text-steel">{s.blurb}</p>
        </article>
      ))}
    </div>
    <p class="mt-6 text-sm text-steel">
      Don’t see what you need? <a href="#quote" class="font-600 text-sky underline">Ask us</a> — we’ll point you the right way.
    </p>
  </div>
</section>
