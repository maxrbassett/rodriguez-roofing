---
import * as site from '@data/site';
import { Image } from 'astro:assets';
import logo from '@assets/logo.png';
const year = new Date().getFullYear();
---

<footer class="bg-slate-deep text-steel-300">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <div class="inline-flex rounded-xl bg-white p-3">
        <Image src={logo} alt={site.name} class="h-14 w-auto" />
      </div>
      <p class="mt-4 max-w-md text-sm">{site.trustLine}</p>
      <p class="mt-2 text-sm">{site.serviceAreaLine}</p>
    </div>

    <div>
      <h3 class="font-display text-sm font-600 uppercase tracking-wide text-white">Contact</h3>
      <ul class="mt-3 grid gap-2 text-sm">
        <li><a href={`tel:${site.phoneTel}`} class="text-steel-300 underline hover:text-white">{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`} class="text-steel-300 underline hover:text-white">{site.email}</a></li>
        <li><a href="#quote" class="text-steel-300 underline hover:text-white">Request a free quote</a></li>
      </ul>
      <p class="mt-3 text-xs text-steel-300/80">{site.languagesNote}</p>
    </div>

    <div>
      <h3 class="font-display text-sm font-600 uppercase tracking-wide text-white">Hours & area</h3>
      <ul class="mt-3 grid gap-2 text-sm">
        <li class="flex items-center justify-between gap-3">
          <span>Hours</span>
          <a href={`tel:${site.phoneTel}`} class="text-steel-300 underline hover:text-white">{site.hoursNote}</a>
        </li>
        <li>{site.baseLine}</li>
      </ul>
      <p class="mt-3 text-xs text-steel-300/80">Serving the Carolinas — call to check your area.</p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-4 py-5 text-xs text-steel-300/80 sm:px-6">
      <p>© {year} {site.name}. All rights reserved. · {site.languagesNote}</p>
      <p class="mt-1">
        Licensing, insurance, and financing details to be confirmed with the owner before launch.
      </p>
    </div>
  </div>
</footer>
