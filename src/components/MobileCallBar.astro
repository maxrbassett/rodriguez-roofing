---
import * as site from '@data/site';
---

<div class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-2 gap-px border-t border-steel-300 bg-steel-300 lg:hidden">
  <a
    href={`tel:${site.phoneTel}`}
    class="flex items-center justify-center gap-2 bg-white py-3 font-display text-sm font-600 uppercase tracking-wide text-slate-deep no-underline"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1l-2.2 2.3z"/>
    </svg>
    Call
  </a>
  <a
    href="#quote"
    class="flex items-center justify-center gap-2 bg-sky py-3 font-display text-sm font-600 uppercase tracking-wide text-white no-underline"
  >
    Free quote
  </a>
</div>
<!-- Spacer so the fixed bar never covers footer content on mobile -->
<div class="h-14 lg:hidden" aria-hidden="true"></div>
