---
import * as site from '@data/site';
const f = site.financing;
---

<section id="financing" class="bg-slate-deep py-16 text-white sm:py-24" aria-labelledby="financing-title">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <p class="mb-2 font-display text-sm font-600 uppercase tracking-[0.22em] text-sky-bright">Make it easy</p>
    <h2 id="financing-title" class="font-display text-3xl font-800 uppercase text-white sm:text-4xl">{f.heading}</h2>
    <p class="mt-3 max-w-2xl text-lg text-steel-300">{f.blurb}</p>

    <div class="mt-10 grid gap-5 sm:grid-cols-3">
      {f.financingPoints.map((p) => (
        <div class="rounded-xl border border-white/15 bg-white/5 p-6">
          <h3 class="font-display text-lg font-700 text-white">{p.title}</h3>
          <p class="mt-2 text-steel-300">{p.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12">
      <h3 class="font-display text-2xl font-700 uppercase text-white">How insurance claims work with us</h3>
      <ol class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {f.claimSteps.map((s) => (
          <li class="relative rounded-xl border border-white/15 bg-white/5 p-6">
            <span aria-hidden="true" class="mb-3 grid h-10 w-10 place-items-center rounded-full bg-sky font-display text-lg font-700 text-white">{s.step}</span>
            <h4 class="font-display text-lg font-600 text-white">{s.title}</h4>
            <p class="mt-2 text-sm text-steel-300">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>

    <p class="mt-8 max-w-3xl rounded-lg border border-white/15 bg-white/5 p-4 text-sm text-steel-300">
      <strong class="text-white">Please note:</strong> {f.disclaimer}
    </p>
  </div>
</section>
