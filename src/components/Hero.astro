---
import * as site from '@data/site';
import { Image } from 'astro:assets';
import heroImg from '@assets/roof-stock.jpeg';
---

<section id="top" class="relative isolate flex min-h-[34rem] items-center overflow-hidden bg-slate-deep text-white lg:min-h-[40rem]">
  {/* Full-bleed background photo — a muted, navy-tinted texture, not a focal image */}
  <Image
    src={heroImg}
    alt=""
    widths={[768, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-10 h-full w-full object-cover"
  />
  {/* Uniform navy tint — mutes the gray shingles into a subtle blue-toned texture */}
  <div class="absolute inset-0 -z-10 bg-slate-deep/75"></div>
  {/* Extra darkening on the left for headline contrast */}
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-deep/55 via-transparent to-transparent"></div>

  <div class="mx-auto w-full max-w-6xl px-4 py-20 sm:px-6 lg:py-28">
    <div class="max-w-2xl">
      <p class="mb-4 font-display text-sm font-600 uppercase tracking-[0.22em] text-sky-bright">
        {site.heroAreaLine}
      </p>
      <h1 class="font-display text-4xl font-800 leading-[1.05] text-white sm:text-5xl lg:text-6xl">
        {site.heroTagline}
      </h1>
      <p class="mt-5 max-w-xl text-lg text-steel-100">
        {site.heroSubhead}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="#quote"
          class="inline-flex items-center justify-center rounded-full bg-sky px-7 py-3.5 font-display text-base font-600 uppercase tracking-wide text-white no-underline transition-colors hover:bg-sky-deep"
        >
          Request a free quote
        </a>
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/70 bg-slate-deep/30 px-7 py-3.5 font-display text-base font-600 uppercase tracking-wide text-white no-underline backdrop-blur-sm transition-colors hover:bg-white/10"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1l-2.2 2.3z"/>
          </svg>
          Call {site.phone}
        </a>
      </div>

      <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2">
        {site.heroBadges.map((b) => (
          <li class="flex items-center gap-2 text-sm font-500 text-steel-100">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12l4 4L19 7" stroke="#4aa8e0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {b}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
